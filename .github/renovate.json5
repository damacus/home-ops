{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>damacus/renovate-config",
    "github>damacus/renovate-config:autoMergeGitHubActions.json5",
    "github>damacus/renovate-config:cnpg.json5",
    "github>damacus/renovate-config:customManagers.json5",
    "github>damacus/renovate-config:groups.json",
    "github>damacus/renovate-config:labels.json5",
    "github>damacus/renovate-config:semanticCommits.json5",
    "github>damacus/renovate-config:packageRules.json5",
    "github>damacus/renovate-config:autoMergeSelect.json5",
  ],
  packageRules: [
    {
      description: "Auto-merge non-major updates for selected home-ops assets",
      matchPackageNames: [
        "ghcr.io/coder/code-server",
        "ghcr.io/damacus/med-tracker",
        "ghcr.io/mealie-recipes/mealie",
        "ghcr.io/paperless-ngx/paperless-ngx",
        "registry.k8s.io/kubectl",
        "ghcr.io/zitadel/zitadel",
        "victoria-metrics-k8s-stack",
        "zitadel",
      ],
      matchUpdateTypes: ["digest", "minor", "patch", "pin", "pinDigest"],
      automerge: true,
    },
  ],
}
