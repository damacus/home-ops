NAMESPACE=home
APP_DEPLOYMENTS=mealie
APP_WORKLOADS=statefulset/mealie
HELMRELEASE=mealie

BLUE_CLUSTER=mealie
GREEN_CLUSTER=mealie-green
BLUE_DATABASE=mealie
GREEN_DATABASE=mealie
BLUE_USER=mealie
GREEN_USER=mealie

BLUE_APP_SECRET=mealie-db
GREEN_APP_SECRET=mealie-db
REQUIRED_APP_SECRET_KEYS="username password"
REPLICA_IDENTITY_FULL_TABLES="public.cookbooks_to_categories public.households_to_ingredient_foods public.recipes_to_tags public.group_to_categories public.households_to_tools public.cookbooks_to_tools public.plan_rules_to_tags public.cookbooks_to_tags public.recipes_to_tools public.plan_rules_to_categories public.recipes_to_categories public.plan_rules_to_households"

PUBLICATION_NAME=mealie-green-pub
SUBSCRIPTION_NAME=mealie-green-sub
PUBLICATION_PG_NAME=mealie_green_pub
SUBSCRIPTION_PG_NAME=mealie_green_sub

STATE_DIR=.migration-state/mealie
MIGRATION_MANIFEST_DIR=${REPO_ROOT}/kubernetes/apps/home/mealie-db/migration
HELMRELEASE_PATH=${REPO_ROOT}/kubernetes/apps/home/mealie/app/helmrelease.yaml

CUTOVER_TARGET_TYPE=helm-value
HELM_VALUE_PATH=.spec.values.controllers.mealie.containers.app.env.POSTGRES_SERVER
BLUE_HELM_VALUE="{{ .Release.Name }}-rw"
GREEN_HELM_VALUE=mealie-green-rw
POSTCHECK_ENV_VAR=POSTGRES_SERVER
REQUIRE_APP_CONNECTIONS=false
HEALTH_URL=https://mealie.damacus.io
PROM_POD_REGEX=mealie.*
