NAMESPACE=dev
APP_DEPLOYMENTS="forgejo"
HELMRELEASE=forgejo

BLUE_CLUSTER=forgejo
GREEN_CLUSTER=forgejo-green
BLUE_DATABASE=forgejo
GREEN_DATABASE=forgejo
BLUE_USER=forgejo
GREEN_USER=forgejo

BLUE_APP_SECRET=forgejo-db
GREEN_APP_SECRET=forgejo-db
REQUIRED_APP_SECRET_KEYS="username password"

PUBLICATION_NAME=forgejo-green-pub
SUBSCRIPTION_NAME=forgejo-green-sub
PUBLICATION_PG_NAME=forgejo_green_pub
SUBSCRIPTION_PG_NAME=forgejo_green_sub

STATE_DIR=.migration-state/forgejo
MIGRATION_MANIFEST_DIR=${REPO_ROOT}/kubernetes/apps/dev/forgejo-db/migration
HELMRELEASE_PATH=${REPO_ROOT}/kubernetes/apps/dev/forgejo/app/helmrelease.yaml

CUTOVER_TARGET_TYPE=helm-value
HELM_VALUE_PATH=.spec.values.gitea.config.database.HOST
BLUE_HELM_VALUE=forgejo-rw.dev.svc.cluster.local:5432
GREEN_HELM_VALUE=forgejo-green-rw.dev.svc.cluster.local:5432
POSTCHECK_ENV_VAR=
HEALTH_URL=https://forgejo.ironstone.casa/api/healthz
PROM_POD_REGEX=forgejo.*
